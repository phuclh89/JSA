NODE_ENV=development
APP_NAME=JSAMS
APP_PORT=3000
API_PREFIX=/api
API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://localhost:5173
ORACLE_CLIENT_MODE=thick
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=host:1521/service-name
ORACLE_CLIENT_LIB_DIR=C:/path/to/oracle/instantclient
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_POOL_TIMEOUT_SECONDS=60
ORACLE_QUEUE_TIMEOUT_MS=10000
ORACLE_STATEMENT_CACHE_SIZE=50
ORACLE_CONNECTION_TIMEOUT_MS=10000
ORACLE_ENABLE_EVENTS=false
RUN_ORACLE_INTEGRATION_TESTS=false
PHASE1_SMOKE_USER=
AUTH_MODE=development
OIDC_ENABLED=false
OIDC_TENANT_ID=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
LOCAL_SITE_CODE=DEV
LOCAL_SITE_ID=
# Fail-closed Phase 3 boundaries. Populate only with approved permission codes and numbering policy.
JSA_PERMISSION_VIEW=
JSA_PERMISSION_CREATE=
JSA_PERMISSION_EDIT=
JSA_PERMISSION_CANCEL=
# Configure all Phase 4 action mappings together. Values are governed permission codes, not defaults.
JSA_PERMISSION_SUBMIT=
JSA_PERMISSION_APPROVE=
JSA_PERMISSION_RETURN=
JSA_PERMISSION_REJECT=
JSA_PERMISSION_COMMENT=
JSA_PERMISSION_WORKFLOW_VIEW=
JSA_PERMISSION_WORKFLOW_ADMIN=
JSA_NUMBER_TEMPLATE=
JSA_NUMBER_UNIQUENESS_SCOPE=
BOOTSTRAP_SITE_CODE=
BOOTSTRAP_SITE_NAME=
BOOTSTRAP_SITE_TIMEZONE=Asia/Ho_Chi_Minh
BOOTSTRAP_SEQUENCE_RANGE_START=
BOOTSTRAP_SEQUENCE_RANGE_END=
BOOTSTRAP_ADMIN_IDENTITY_KEY=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_DISPLAY_NAME=
BOOTSTRAP_ADMIN_EMAIL=
PHASE2_BOOTSTRAP_ACTOR=
PHASE4_BOOTSTRAP_ACTOR=
LOG_LEVEL=info
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_AUTH_MODE=development
VITE_DEV_USER=admin
